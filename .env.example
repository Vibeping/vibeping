# VibePing Environment Variables

# Database (Supabase)
DATABASE_URL=postgresql://postgres:vibeping@localhost:5432/vibeping
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_VIBEPING_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=https://app.vibeping.dev

# Uptime Cron
UPTIME_CRON_SECRET=your-cron-secret
