# VibePing Dashboard Environment Variables
# Copy to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=https://app.vibeping.dev
NEXT_PUBLIC_VIBEPING_API_URL=https://app.vibeping.dev/api

# Uptime Cron
UPTIME_CRON_SECRET=your-cron-secret
